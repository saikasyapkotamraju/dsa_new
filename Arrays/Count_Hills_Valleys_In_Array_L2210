You are given a 0-indexed integer array nums. An index i is part of a hill in nums if the closest non-equal neighbors of i are smaller than nums[i]. Similarly, an index i is part of a valley in nums if the closest non-equal neighbors of i are larger than nums[i]. Adjacent indices i and j are part of the same hill or valley if nums[i] == nums[j].
Note that for an index to be part of a hill or valley, it must have a non-equal neighbor on both the left and right of the index.
Return the number of hills and valleys in nums.


Sol 1 : modify given array by removing duplicates and compare each index with prev and next
import java.util.*;
class Solution {
    public int countHillValley(int[] nums) {
        int n = nums.length;
        if(n<=2)return 0;
        int result = 0;
        List<Integer> reduced = new ArrayList<>();
        reduced.add(nums[0]);
        for(int i=1; i<n; i++)
        {
            if(nums[i]!=nums[i-1])
            {
                reduced.add(nums[i]);
            }
        }

        for(int i=1; i<reduced.size()-1; i++)
        {
            int prev = reduced.get(i-1);
            int curr = reduced.get(i);
            int next = reduced.get(i+1);

            if((curr < prev && curr < next) || (curr > prev && curr > next))
            {
                result++;
            }
        }

        return result;
    }
}

Sol 2 : without modifying the given array, we will identify non equal neighbours at each index
import java.util.*;
class Solution {
    public int countHillValley(int[] nums) {
        int n = nums.length;
        if(n<=2)return 0;
        int result = 0;
        for(int i=1; i<n-1; i++){
            if(nums[i]==nums[i-1])continue;
            int val = nums[i];
            int left = i-1;
            int right = i+1;
            while(right<n && nums[right]==val)right++;
            if(left>=0 && right<n)
            {
                if((val < nums[left] && val < nums[right]) || (val > nums[left] && val > nums[right]))result++;
            }
        }
        return result;
    }
}
